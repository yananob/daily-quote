{
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.5",
        "google/cloud-functions-framework": "^1.4",
        "google/cloud-firestore": "^1.54",
        "linecorp/line-bot-sdk": "^12.3",
        "vlucas/phpdotenv": "^5.6",
        "eftec/bladeone": "^4.19",
        "phpgt/csrf": "^1.9",
        "phpgt/session": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "php -S localhost:${PORT:-8080} tests/bootstrap_http.php"
        ]
    }
}

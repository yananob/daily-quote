{
    "name": "yananob/daily-quote",
    "type": "project",
    "description": "Daily Quote",
    "keywords": [],
    "require": {
        "php": "^7.3|^8.0",
        "google/cloud-functions-framework": "^1.1",
        "google/cloud-firestore": "^1.34",
        "google/cloud-storage": "^1.42",
        "guzzlehttp/guzzle": "^7.0.1",
        "yananob/my-tools": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.10"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:yananob/my-tools.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": [
            "php -S localhost:8080 public/index.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
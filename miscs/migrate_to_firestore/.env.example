# =================================================================
#  Example Environment Configuration for Migration Script
# =================================================================

# --- SQLite Configuration ---
# Path to the source SQLite database file.
# Example: SQLITE_DB_PATH=../src/database/database.sqlite
SQLITE_DB_PATH=

# --- Firestore Configuration ---
# Your Google Cloud Project ID where the Firestore database is located.
# This is required to connect to Firestore.
# NOTE: This is currently unused until the `google/cloud-firestore` dependency can be installed.
# Example: FIRESTORE_PROJECT_ID=my-gcp-project-id
FIRESTORE_PROJECT_ID=

GOOGLE_APPLICATION_CREDENTIALS=

{
    "name": "yananob/daily-quote",
    "description": "A daily quote application using Google Cloud Functions and Firestore",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.5",
        "google/cloud-functions-framework": "^1.4",
        "google/cloud-firestore": "^1.54",
        "linecorp/line-bot-sdk": "^12.3",
        "eftec/bladeone": "^4.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
